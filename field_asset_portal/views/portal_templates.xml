<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Portal Home Tile -->
    <template id="portal_my_home_assets" name="Portal My Home: Assets"
              customize_show="True" inherit_id="portal.portal_my_home">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="icon" t-value="'/field_asset_portal/static/description/icon.svg'"/>
                <t t-set="title">Your Assets</t>
                <t t-set="text">View your assets, warranties and service history</t>
                <t t-set="url" t-value="'/my/assets'"/>
                <t t-set="placeholder_count" t-value="'asset_count'"/>
                <t t-set="count" t-value="asset_count"/>
            </t>
        </xpath>
    </template>

    <!-- Breadcrumb Extension -->
    <template id="portal_breadcrumbs_field_asset" inherit_id="portal.portal_breadcrumbs">
        <xpath expr="//ol" position="inside">
            <!-- My Assets list: active -->
            <t t-if="page_name == 'assets'">
                <li class="breadcrumb-item ms-1 active">My Assets</li>
            </t>
            <!-- All asset sub-pages: My Assets as link -->
            <t t-if="page_name in ('asset_detail', 'equipment_detail', 'service_request')">
                <li class="breadcrumb-item ms-1">
                    <a href="/my/assets">My Assets</a>
                </li>
            </t>
            <!-- Asset detail: asset name active -->
            <t t-if="page_name == 'asset_detail' and asset">
                <li class="breadcrumb-item ms-1 active"><t t-out="asset.name"/></li>
            </t>
            <!-- Equipment detail: asset name as link, equipment name active -->
            <t t-if="page_name == 'equipment_detail' and equipment">
                <li class="breadcrumb-item ms-1">
                    <a t-attf-href="/my/assets/#{equipment.asset_id.id}">
                        <t t-esc="equipment.asset_id.name"/>
                    </a>
                </li>
                <li class="breadcrumb-item ms-1 active"><t t-esc="equipment.name"/></li>
            </t>
            <!-- Service request: optional asset link, then active label -->
            <t t-if="page_name == 'service_request'">
                <t t-if="asset">
                    <li class="breadcrumb-item ms-1">
                        <a t-attf-href="/my/assets/#{asset.id}"><t t-out="asset.name"/></a>
                    </li>
                </t>
                <li class="breadcrumb-item ms-1 active">New Service Request</li>
            </t>
        </xpath>
    </template>

    <!-- Asset List -->
    <template id="portal_my_assets" name="My Assets">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">My Assets</t>
            </t>
            <t t-if="not assets">
                <div class="alert alert-info">No assets found.</div>
            </t>
            <t t-if="assets">
                <!-- Single-location shortcut: show one "Request Service" button above the table -->
                <t t-set="unique_locations" t-value="assets.mapped('location_id')"/>
                <t t-if="len(unique_locations) == 1">
                    <div class="mb-3">
                        <a t-attf-href="/my/locations/#{unique_locations[0].id}/service/new"
                           class="btn btn-primary btn-sm">
                            Request Service
                        </a>
                    </div>
                </t>
                <div class="table-responsive">
                    <table class="table table-hover o_portal_my_doc_table">
                        <thead>
                            <tr>
                                <th>Asset Name</th>
                                <th>Location</th>
                                <th>Contractor</th>
                                <th>Service Company</th>
                                <th>Warranty Status</th>
                                <th>Warranty End</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="assets" t-as="asset">
                                <tr>
                                    <td>
                                        <a t-attf-href="/my/assets/#{asset.id}">
                                            <t t-out="asset.name"/>
                                        </a>
                                    </td>
                                    <td><t t-out="asset.location_id.name or ''"/></td>
                                    <td><t t-out="asset.contractor_id.name or ''"/></td>
                                    <td><t t-out="asset.service_company_id.name or ''"/></td>
                                    <td>
                                        <t t-if="asset.warranty_status == 'active'">
                                            <span class="badge bg-success">Active</span>
                                        </t>
                                        <t t-elif="asset.warranty_status == 'expiring_soon'">
                                            <span class="badge bg-warning text-dark">Expiring Soon</span>
                                        </t>
                                        <t t-elif="asset.warranty_status == 'expired'">
                                            <span class="badge bg-danger">Expired</span>
                                        </t>
                                        <t t-else="">
                                            <span class="badge bg-secondary">Not Set</span>
                                        </t>
                                    </td>
                                    <td>
                                        <t t-if="asset.warranty_end">
                                            <t t-out="asset.warranty_end"/>
                                        </t>
                                        <t t-else="">&#8212;</t>
                                    </td>
                                    <!-- Per-row button only when multiple locations -->
                                    <td>
                                        <t t-if="len(unique_locations) != 1">
                                            <a t-attf-href="/my/assets/#{asset.id}/service/new"
                                               class="btn btn-outline-primary btn-sm">
                                                Request Service
                                            </a>
                                        </t>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>
    </template>

    <!-- Asset Detail -->
    <template id="portal_asset_detail" name="Asset Detail">
        <t t-call="portal.portal_layout">
            <h3 class="mb-4"><t t-out="asset.name"/></h3>

            <div class="row mb-4">
                <div class="col-md-6 mb-3">
                    <div class="card h-100">
                        <div class="card-header"><strong>Asset Details</strong></div>
                        <div class="card-body">
                            <dl class="row mb-0">
                                <dt class="col-sm-5">Location</dt>
                                <dd class="col-sm-7"><t t-out="asset.location_id.name or '&#8212;'"/></dd>
                                <dt class="col-sm-5">Owner/Occupant</dt>
                                <dd class="col-sm-7"><t t-out="asset.location_id.owner_id.name or '&#8212;'"/></dd>
                                <dt class="col-sm-5">Contractor</dt>
                                <dd class="col-sm-7"><t t-out="asset.contractor_id.name or '&#8212;'"/></dd>
                                <dt class="col-sm-5">Service Company</dt>
                                <dd class="col-sm-7"><t t-out="asset.service_company_id.name or '&#8212;'"/></dd>
                            </dl>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 mb-3">
                    <div class="card h-100">
                        <div class="card-header"><strong>Warranty</strong></div>
                        <div class="card-body">
                            <dl class="row mb-0">
                                <dt class="col-sm-5">Start</dt>
                                <dd class="col-sm-7"><t t-out="asset.warranty_start or '&#8212;'"/></dd>
                                <dt class="col-sm-5">End</dt>
                                <dd class="col-sm-7"><t t-out="asset.warranty_end or '&#8212;'"/></dd>
                                <dt class="col-sm-5">Status</dt>
                                <dd class="col-sm-7">
                                    <t t-if="asset.warranty_status == 'active'">
                                        <span class="badge bg-success">Active</span>
                                    </t>
                                    <t t-elif="asset.warranty_status == 'expiring_soon'">
                                        <span class="badge bg-warning text-dark">Expiring Soon</span>
                                    </t>
                                    <t t-elif="asset.warranty_status == 'expired'">
                                        <span class="badge bg-danger">Expired</span>
                                    </t>
                                    <t t-else="">
                                        <span class="badge bg-secondary">Not Set</span>
                                    </t>
                                </dd>
                            </dl>
                        </div>
                    </div>
                </div>
            </div>

            <h4 class="mb-3">Equipment</h4>
            <t t-if="not equipment">
                <p class="text-muted">No equipment recorded for this asset.</p>
            </t>
            <t t-if="equipment">
                <div class="table-responsive mb-4">
                    <table class="table table-sm table-hover">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Manufacturer</th>
                                <th>Manufacturer Serial</th>
                                <th>Our Part Code</th>
                                <th>Mfr Warranty</th>
                                <th>Our Warranty</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="equipment" t-as="eq">
                                <tr>
                                    <td><a t-attf-href="/my/equipment/#{eq.id}" t-esc="eq.name"/></td>
                                    <td><t t-out="eq.manufacturer_id.name or '&#8212;'"/></td>
                                    <td><t t-out="eq.manufacturer_serial or '&#8212;'"/></td>
                                    <td><t t-out="eq.your_part_code or '&#8212;'"/></td>
                                    <td>
                                        <t t-if="eq.manufacturer_warranty_status == 'active'"><span class="badge bg-success">Active</span></t>
                                        <t t-elif="eq.manufacturer_warranty_status == 'expiring_soon'"><span class="badge bg-warning text-dark">Expiring Soon</span></t>
                                        <t t-elif="eq.manufacturer_warranty_status == 'expired'"><span class="badge bg-danger">Expired</span></t>
                                        <t t-else=""><span class="badge bg-secondary">Not Set</span></t>
                                    </td>
                                    <td>
                                        <t t-if="eq.our_warranty_status == 'active'"><span class="badge bg-success">Active</span></t>
                                        <t t-elif="eq.our_warranty_status == 'expiring_soon'"><span class="badge bg-warning text-dark">Expiring Soon</span></t>
                                        <t t-elif="eq.our_warranty_status == 'expired'"><span class="badge bg-danger">Expired</span></t>
                                        <t t-else=""><span class="badge bg-secondary">Not Set</span></t>
                                    </td>
                                    <td>
                                        <a t-attf-href="/my/equipment/#{eq.id}/service/new"
                                           class="btn btn-outline-primary btn-sm">
                                            Request Service
                                        </a>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>

            <h4 class="mb-3">Service History</h4>
            <t t-if="not service_actions">
                <p class="text-muted">No service actions recorded for this asset.</p>
            </t>
            <t t-if="service_actions">
                <div class="table-responsive mb-4">
                    <table class="table table-sm table-hover">
                        <thead>
                            <tr>
                                <th>Ref</th>
                                <th>Summary</th>
                                <th>Type</th>
                                <th>Status</th>
                                <th>Date Requested</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="service_actions" t-as="sa">
                                <tr>
                                    <td><t t-out="sa.ref or '&#8212;'"/></td>
                                    <td><t t-out="sa.name"/></td>
                                    <td><t t-out="sa.action_type"/></td>
                                    <td>
                                        <t t-if="sa.state == 'pending'"><span class="badge bg-secondary">Pending</span></t>
                                        <t t-elif="sa.state == 'draft'"><span class="badge bg-info text-dark">Approved</span></t>
                                        <t t-elif="sa.state == 'confirmed'"><span class="badge bg-primary">Confirmed</span></t>
                                        <t t-elif="sa.state == 'in_progress'"><span class="badge bg-warning text-dark">In Progress</span></t>
                                        <t t-elif="sa.state == 'done'"><span class="badge bg-success">Done</span></t>
                                        <t t-elif="sa.state == 'declined'"><span class="badge bg-danger">Declined</span></t>
                                        <t t-else=""><span class="badge bg-secondary">Cancelled</span></t>
                                    </td>
                                    <td><t t-out="sa.date_requested"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>

            <div class="mt-2">
                <a t-attf-href="/my/assets/#{asset.id}/service/new" class="btn btn-primary">
                    Request Service
                </a>
            </div>

            <div class="mt-4" id="asset_chatter">
                <t t-call="portal.message_thread">
                    <t t-set="object" t-value="asset"/>
                    <t t-set="token" t-value="asset.access_token"/>
                    <t t-set="pid" t-value="request.env.user.partner_id.id"/>
                    <t t-set="hash" t-value="asset.access_token"/>
                </t>
            </div>
        </t>
    </template>

    <!-- Equipment Detail -->
    <template id="portal_equipment_detail" name="Equipment Detail">
        <t t-call="portal.portal_layout">
            <h3 t-esc="equipment.name" class="mt-3"/>

            <div class="row mt-3">
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header"><strong>Equipment Details</strong></div>
                        <div class="card-body">
                            <table class="table table-sm">
                                <tr><th>Asset</th><td><a t-attf-href="/my/assets/#{equipment.asset_id.id}" t-esc="equipment.asset_id.name"/></td></tr>
                                <tr><th>Location</th><td><t t-esc="equipment.asset_id.location_id.name or '-'"/></td></tr>
                                <tr><th>Manufacturer</th><td><t t-esc="equipment.manufacturer_id.name or '-'"/></td></tr>
                                <tr><th>Manufacturer Part Code</th><td><t t-esc="equipment.manufacturer_part_code or '-'"/></td></tr>
                                <tr><th>Manufacturer Serial</th><td><t t-esc="equipment.manufacturer_serial or '-'"/></td></tr>
                                <tr><th>Our Part Code</th><td><t t-esc="equipment.your_part_code or '-'"/></td></tr>
                                <tr><th>Our Serial</th><td><t t-esc="equipment.your_serial or '-'"/></td></tr>
                                <tr><th>Service Company</th><td><t t-esc="equipment.service_company_id.name or '-'"/></td></tr>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header"><strong>Warranty</strong></div>
                        <div class="card-body">
                            <table class="table table-sm">
                                <tr><th>Manufacturer Warranty Start</th><td><t t-esc="equipment.manufacturer_warranty_start or '-'"/></td></tr>
                                <tr><th>Manufacturer Warranty End</th><td><t t-esc="equipment.manufacturer_warranty_end or '-'"/></td></tr>
                                <tr><th>Manufacturer Warranty Status</th>
                                    <td>
                                        <t t-if="equipment.manufacturer_warranty_status == 'active'"><span class="badge bg-success">Active</span></t>
                                        <t t-elif="equipment.manufacturer_warranty_status == 'expiring_soon'"><span class="badge bg-warning text-dark">Expiring Soon</span></t>
                                        <t t-elif="equipment.manufacturer_warranty_status == 'expired'"><span class="badge bg-danger">Expired</span></t>
                                        <t t-else=""><span class="badge bg-secondary">Not Set</span></t>
                                    </td>
                                </tr>
                                <tr><th>Our Warranty Start</th><td><t t-esc="equipment.our_warranty_start or '-'"/></td></tr>
                                <tr><th>Our Warranty End</th><td><t t-esc="equipment.our_warranty_end or '-'"/></td></tr>
                                <tr><th>Our Warranty Status</th>
                                    <td>
                                        <t t-if="equipment.our_warranty_status == 'active'"><span class="badge bg-success">Active</span></t>
                                        <t t-elif="equipment.our_warranty_status == 'expiring_soon'"><span class="badge bg-warning text-dark">Expiring Soon</span></t>
                                        <t t-elif="equipment.our_warranty_status == 'expired'"><span class="badge bg-danger">Expired</span></t>
                                        <t t-else=""><span class="badge bg-secondary">Not Set</span></t>
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <h5 class="mt-4">Service History</h5>
            <t t-if="not service_actions">
                <p class="text-muted">No service requests yet.</p>
            </t>
            <t t-if="service_actions">
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Ref</th>
                            <th>Summary</th>
                            <th>Type</th>
                            <th>Status</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="service_actions" t-as="sa">
                            <tr>
                                <td><t t-esc="sa.ref or '-'"/></td>
                                <td><t t-esc="sa.name"/></td>
                                <td><t t-esc="sa.action_type"/></td>
                                <td>
                                    <t t-if="sa.state == 'done'"><span class="badge bg-success">Done</span></t>
                                    <t t-elif="sa.state == 'in_progress'"><span class="badge bg-info">In Progress</span></t>
                                    <t t-elif="sa.state == 'confirmed'"><span class="badge bg-primary">Confirmed</span></t>
                                    <t t-elif="sa.state == 'pending'"><span class="badge bg-warning text-dark">Pending</span></t>
                                    <t t-elif="sa.state == 'declined'"><span class="badge bg-danger">Declined</span></t>
                                    <t t-else=""><span class="badge bg-secondary">Draft</span></t>
                                </td>
                                <td><t t-esc="sa.date_requested"/></td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </t>

            <div class="mt-3">
                <a t-attf-href="/my/equipment/#{equipment.id}/service/new" class="btn btn-primary">Request Service</a>
            </div>

            <div class="mt-4" id="equipment_chatter">
                <t t-call="portal.message_thread">
                    <t t-set="object" t-value="equipment"/>
                    <t t-set="token" t-value="equipment.access_token"/>
                    <t t-set="pid" t-value="request.env.user.partner_id.id"/>
                    <t t-set="hash" t-value="equipment.access_token"/>
                </t>
            </div>
        </t>
    </template>

    <!-- New Service Request Form -->
    <template id="portal_new_service_action" name="New Service Request">
        <t t-call="portal.portal_layout">
            <h3 class="mb-4">New Service Request</h3>

            <form action="/my/service/submit" method="post" class="o_portal_details">
                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                <!-- Location (read-only) -->
                <div class="mb-3">
                    <label class="form-label fw-bold">Location</label>
                    <p class="form-control-plaintext">
                        <t t-if="location">
                            <t t-out="location.name"/>
                        </t>
                        <t t-else="">&#8212;</t>
                    </p>
                </div>

                <!-- Asset dropdown -->
                <div class="mb-3">
                    <label for="asset_id" class="form-label fw-bold">Asset <span class="text-danger">*</span></label>
                    <select class="form-select" id="asset_id" name="asset_id" required="required">
                        <option value="">&#8212; Select asset &#8212;</option>
                        <t t-foreach="assets" t-as="a">
                            <option t-att-value="a.id"
                                    t-att-selected="'selected' if asset and a.id == asset.id else None">
                                <t t-out="a.name"/>
                            </option>
                        </t>
                    </select>
                </div>

                <div class="mb-3">
                    <label for="name" class="form-label fw-bold">Summary <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="name" name="name" required="required"
                           placeholder="Brief description of the issue or request"/>
                </div>

                <div class="mb-3">
                    <label for="action_type" class="form-label fw-bold">Type</label>
                    <select class="form-select" id="action_type" name="action_type">
                        <t t-foreach="action_types" t-as="atype">
                            <option t-att-value="atype[0]"><t t-out="atype[1]"/></option>
                        </t>
                    </select>
                </div>

                <div class="mb-3">
                    <label for="equipment_id" class="form-label fw-bold">Equipment</label>
                    <select class="form-select" id="equipment_id" name="equipment_id">
                        <option value="">&#8212; None &#8212;</option>
                        <t t-foreach="equipment" t-as="eq">
                            <option t-att-value="eq.id"
                                    t-att-selected="'selected' if preselected_equipment_id and eq.id == preselected_equipment_id else None">
                                <t t-out="eq.name"/>
                            </option>
                        </t>
                    </select>
                </div>

                <div class="mb-4">
                    <label for="description" class="form-label fw-bold">Description</label>
                    <textarea class="form-control" id="description" name="description" rows="5"
                              placeholder="Please describe the issue in detail..."/>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Submit Request</button>
                    <t t-if="asset">
                        <a t-attf-href="/my/assets/#{asset.id}" class="btn btn-secondary">Cancel</a>
                    </t>
                    <t t-else="">
                        <a href="/my/assets" class="btn btn-secondary">Cancel</a>
                    </t>
                </div>
            </form>
        </t>
    </template>

</odoo>
