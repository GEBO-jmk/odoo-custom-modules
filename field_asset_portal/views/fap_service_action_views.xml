<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="fap_service_action_view_form" model="ir.ui.view">
        <field name="name">fap.service.action.view.form</field>
        <field name="model">fap.service.action</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_set_pending" string="Send for Review" type="object"
                            invisible="state != 'draft'" class="btn-primary"/>
                    <button name="action_approve" string="Approve" type="object"
                            invisible="state != 'pending'" class="btn-primary"/>
                    <button name="action_decline" string="Decline" type="object"
                            invisible="state != 'pending'" class="btn-secondary"/>
                    <button name="action_confirm" string="Confirm" type="object"
                            invisible="state != 'draft'" class="btn-primary"/>
                    <button name="action_start" string="Start" type="object"
                            invisible="state != 'confirmed'" class="btn-primary"/>
                    <button name="action_done" string="Mark Done" type="object"
                            invisible="state != 'in_progress'" class="btn-primary"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            invisible="state in ('done', 'cancelled')" class="btn-secondary"/>
                    <button name="action_reset" string="Reset to Draft" type="object"
                            invisible="state != 'cancelled'" class="btn-secondary"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="pending,draft,confirmed,in_progress,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Summary"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="ref"/>
                            <field name="asset_id"/>
                            <field name="equipment_id"
                                domain="[('asset_id', '=', asset_id)]"/>
                            <field name="location_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Details">
                            <group>
                                <group>
                                    <field name="action_type"/>
                                    <field name="priority"/>
                                    <field name="requested_by_id"/>
                                    <field name="assigned_to_id"/>
                                </group>
                                <group>
                                    <field name="date_requested"/>
                                    <field name="date_scheduled"/>
                                    <field name="date_completed"/>
                                </group>
                            </group>
                        </page>
                        <page string="Description">
                            <field name="description" nolabel="1"/>
                        </page>
                        <page string="Resolution">
                            <field name="resolution" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="fap_service_action_view_list" model="ir.ui.view">
        <field name="name">fap.service.action.view.list</field>
        <field name="model">fap.service.action</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="asset_id"/>
                <field name="action_type"/>
                <field name="priority"/>
                <field name="assigned_to_id"/>
                <field name="date_scheduled"/>
                <field name="state" widget="badge"
                    decoration-muted="state == 'draft'"
                    decoration-info="state == 'confirmed'"
                    decoration-warning="state == 'in_progress'"
                    decoration-success="state == 'done'"
                    decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <record id="fap_service_action_view_search" model="ir.ui.view">
        <field name="name">fap.service.action.view.search</field>
        <field name="model">fap.service.action</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="asset_id"/>
                <filter name="state_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="state_confirmed" string="Confirmed" domain="[('state', '=', 'confirmed')]"/>
                <filter name="state_in_progress" string="In Progress" domain="[('state', '=', 'in_progress')]"/>
                <filter name="type_installation" string="Installation" domain="[('action_type', '=', 'installation')]"/>
                <filter name="type_preventive" string="Preventive" domain="[('action_type', '=', 'preventive')]"/>
                <filter name="type_corrective" string="Corrective" domain="[('action_type', '=', 'corrective')]"/>
                <filter name="type_predictive" string="Predictive" domain="[('action_type', '=', 'predictive')]"/>
                <filter name="type_calibration" string="Calibration" domain="[('action_type', '=', 'calibration')]"/>
                <filter name="type_inspection" string="Inspection" domain="[('action_type', '=', 'inspection')]"/>
                <filter name="type_parts_replacement" string="Parts Replacement" domain="[('action_type', '=', 'parts_replacement')]"/>
                <separator/>
                <filter name="group_by_action_type" string="Type" context="{'group_by': 'action_type'}"/>
                <filter name="group_by_state" string="Status" context="{'group_by': 'state'}"/>
                <filter name="group_by_assigned_to" string="Assigned To" context="{'group_by': 'assigned_to_id'}"/>
            </search>
        </field>
    </record>

    <record id="fap_service_action_action" model="ir.actions.act_window">
        <field name="name">Service Actions</field>
        <field name="res_model">fap.service.action</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="fap_menu_service_actions"
        name="Service Actions"
        parent="fap_menu_root"
        action="fap_service_action_action"
        sequence="40"/>

</odoo>
