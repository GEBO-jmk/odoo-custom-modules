<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="fap_equipment_view_form" model="ir.ui.view">
        <field name="name">fap.equipment.view.form</field>
        <field name="model">fap.equipment</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" icon="fa-wrench" type="object"
                                name="action_open_service_actions"
                                context="{'default_equipment_id': id}">
                            <field name="service_action_count" widget="statinfo" string="Service Actions"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Equipment Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="asset_id"/>
                            <field name="location_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Identification">
                            <group>
                                <group string="Manufacturer">
                                    <field name="manufacturer_id"/>
                                    <field name="manufacturer_part_code"/>
                                    <field name="manufacturer_serial"/>
                                </group>
                                <group string="Our References">
                                    <field name="your_part_code"/>
                                    <field name="your_serial"/>
                                </group>
                            </group>
                        </page>
                        <page string="Manufacturer Warranty">
                            <group>
                                <field name="manufacturer_warranty_start"/>
                                <field name="manufacturer_warranty_duration"/>
                                <field name="manufacturer_warranty_end"/>
                                <field name="manufacturer_warranty_status" widget="badge"
                                    decoration-success="manufacturer_warranty_status == 'active'"
                                    decoration-warning="manufacturer_warranty_status == 'expiring_soon'"
                                    decoration-danger="manufacturer_warranty_status == 'expired'"
                                    decoration-muted="manufacturer_warranty_status == 'not_set'"/>
                            </group>
                        </page>
                        <page string="Our Warranty">
                            <group>
                                <field name="our_warranty_start"/>
                                <field name="our_warranty_duration"/>
                                <field name="our_warranty_end"/>
                                <field name="our_warranty_status" widget="badge"
                                    decoration-success="our_warranty_status == 'active'"
                                    decoration-warning="our_warranty_status == 'expiring_soon'"
                                    decoration-danger="our_warranty_status == 'expired'"
                                    decoration-muted="our_warranty_status == 'not_set'"/>
                            </group>
                        </page>
                    </notebook>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="fap_equipment_view_list" model="ir.ui.view">
        <field name="name">fap.equipment.view.list</field>
        <field name="model">fap.equipment</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="asset_id"/>
                <field name="manufacturer_id"/>
                <field name="manufacturer_serial"/>
                <field name="manufacturer_warranty_status" widget="badge"
                    decoration-success="manufacturer_warranty_status == 'active'"
                    decoration-warning="manufacturer_warranty_status == 'expiring_soon'"
                    decoration-danger="manufacturer_warranty_status == 'expired'"
                    decoration-muted="manufacturer_warranty_status == 'not_set'"/>
                <field name="our_warranty_status" widget="badge"
                    decoration-success="our_warranty_status == 'active'"
                    decoration-warning="our_warranty_status == 'expiring_soon'"
                    decoration-danger="our_warranty_status == 'expired'"
                    decoration-muted="our_warranty_status == 'not_set'"/>
            </list>
        </field>
    </record>

    <record id="fap_equipment_view_search" model="ir.ui.view">
        <field name="name">fap.equipment.view.search</field>
        <field name="model">fap.equipment</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="asset_id"/>
                <field name="manufacturer_serial"/>
                <field name="your_part_code"/>
                <filter name="our_warranty_active" string="Our Warranty Active" domain="[('our_warranty_status', '=', 'active')]"/>
                <filter name="our_warranty_expiring" string="Our Warranty Expiring" domain="[('our_warranty_status', '=', 'expiring_soon')]"/>
                <filter name="our_warranty_expired" string="Our Warranty Expired" domain="[('our_warranty_status', '=', 'expired')]"/>
                <separator/>
                <filter name="group_by_asset" string="Asset" context="{'group_by': 'asset_id'}"/>
                <filter name="group_by_manufacturer" string="Manufacturer" context="{'group_by': 'manufacturer_id'}"/>
            </search>
        </field>
    </record>

    <record id="fap_equipment_action" model="ir.actions.act_window">
        <field name="name">Equipment</field>
        <field name="res_model">fap.equipment</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="fap_menu_equipment"
        name="Equipment"
        parent="fap_menu_root"
        action="fap_equipment_action"
        sequence="30"/>

</odoo>
