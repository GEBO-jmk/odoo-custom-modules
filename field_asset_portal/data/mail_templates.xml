<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="mail_template_service_action_approved" model="mail.template">
        <field name="name">Service Request Approved</field>
        <field name="model_id" ref="model_fap_service_action"/>
        <field name="subject">Your service request {{ object.ref }} has been approved</field>
        <field name="email_to">{{ object.requested_by_id.email }}</field>
        <field name="body_html" type="html">
<div style="font-family: Arial, sans-serif; font-size: 14px; color: #333333; max-width: 600px; margin: 0 auto;">
    <div style="background-color: #f8f8f8; padding: 24px 32px; border-bottom: 3px solid #2c7be5;">
        <h2 style="margin: 0; color: #2c7be5; font-size: 20px;">Service Request Approved</h2>
    </div>
    <div style="padding: 32px;">
        <p>Dear <t t-out="object.requested_by_id.name"/>,</p>
        <p>
            Your service request <strong><t t-out="object.ref"/></strong> &#8212;
            <t t-out="object.name"/> for asset <strong><t t-out="object.asset_id.name"/></strong>
            at <strong><t t-out="object.location_id.name"/></strong> has been approved.
        </p>
        <p>Our team will be in touch shortly.</p>
        <p style="margin-top: 32px;">Kind regards,<br/><strong>The Service Team</strong></p>
    </div>
    <div style="background-color: #f8f8f8; padding: 16px 32px; font-size: 12px; color: #888888;">
        This is an automated message. Please do not reply directly to this email.
    </div>
</div>
        </field>
    </record>

    <record id="mail_template_service_action_declined" model="mail.template">
        <field name="name">Service Request Declined</field>
        <field name="model_id" ref="model_fap_service_action"/>
        <field name="subject">Regarding your service request {{ object.ref }}</field>
        <field name="email_to">{{ object.requested_by_id.email }}</field>
        <field name="body_html" type="html">
<div style="font-family: Arial, sans-serif; font-size: 14px; color: #333333; max-width: 600px; margin: 0 auto;">
    <div style="background-color: #f8f8f8; padding: 24px 32px; border-bottom: 3px solid #e25c5c;">
        <h2 style="margin: 0; color: #e25c5c; font-size: 20px;">Regarding Your Service Request</h2>
    </div>
    <div style="padding: 32px;">
        <p>Dear <t t-out="object.requested_by_id.name"/>,</p>
        <p>Thank you for contacting us.</p>
        <p>
            Unfortunately we are unable to process your service request
            <strong><t t-out="object.ref"/></strong> &#8212; <t t-out="object.name"/> at this time.
        </p>
        <p>Please do not hesitate to contact our service team if you have any questions.</p>
        <p style="margin-top: 32px;">Kind regards,<br/><strong>The Service Team</strong></p>
    </div>
    <div style="background-color: #f8f8f8; padding: 16px 32px; font-size: 12px; color: #888888;">
        This is an automated message. Please do not reply directly to this email.
    </div>
</div>
        </field>
    </record>

</odoo>
