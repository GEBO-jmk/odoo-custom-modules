            '|', '|',
            ('end_user_id', 'child_of', user.commercial_partner_id.id),
            ('service_company_id', 'child_of', user.commercial_partner_id.id),
            ('contractor_id', 'child_of', user.commercial_partner_id.id)
        ]</field>
    </record>

