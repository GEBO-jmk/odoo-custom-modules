<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="fap_location_rule_portal" model="ir.rule">
        <field name="name">FAP Location: Portal Access</field>
        <field name="model_id" ref="model_fap_location"/>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="domain_force">[
            '|', '|', '|',
            ('owner_id', 'child_of', user.commercial_partner_id.id),
            ('asset_ids.end_user_id', 'child_of', user.commercial_partner_id.id),
            ('asset_ids.service_company_id', 'child_of', user.commercial_partner_id.id),
            ('asset_ids.contractor_id', 'child_of', user.commercial_partner_id.id)
        ]</field>
    </record>

