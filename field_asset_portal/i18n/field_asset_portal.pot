#. module: field_asset_portal
#: model:mail.template,body_html:field_asset_portal.mail_template_service_action_approved
msgid ""
"<div style=\"font-family: Arial, sans-serif; font-size: 14px; color: #333333; max-width: 600px; margin: 0 auto;\">\n"
"    <div style=\"background-color: #f8f8f8; padding: 24px 32px; border-bottom: 3px solid #2c7be5;\">\n"
"        <h2 style=\"margin: 0; color: #2c7be5; font-size: 20px;\">Service Request Approved</h2>\n"
"    </div>\n"
"    <div style=\"padding: 32px;\">\n"
"        <p>Dear <t t-out=\"object.requested_by_id.name\"/>,</p>\n"
"        <p>\n"
"            Your service request <strong><t t-out=\"object.ref\"/></strong> —\n"
"            <t t-out=\"object.name\"/> for asset <strong><t t-out=\"object.asset_id.name\"/></strong>\n"
"            at <strong><t t-out=\"object.location_id.name\"/></strong> has been approved.\n"
"        </p>\n"
"        <p>Our team will be in touch shortly.</p>\n"
"        <p style=\"margin-top: 32px;\">Kind regards,<br/><strong>The Service Team</strong></p>\n"
"    </div>\n"
"    <div style=\"background-color: #f8f8f8; padding: 16px 32px; font-size: 12px; color: #888888;\">\n"
"        This is an automated message. Please do not reply directly to this email.\n"
"    </div>\n"
"</div>\n"
"        "
msgstr ""

#. module: field_asset_portal
#: model:mail.template,body_html:field_asset_portal.mail_template_service_action_declined
msgid ""
"<div style=\"font-family: Arial, sans-serif; font-size: 14px; color: #333333; max-width: 600px; margin: 0 auto;\">\n"
"    <div style=\"background-color: #f8f8f8; padding: 24px 32px; border-bottom: 3px solid #e25c5c;\">\n"
"        <h2 style=\"margin: 0; color: #e25c5c; font-size: 20px;\">Regarding Your Service Request</h2>\n"
"    </div>\n"
"    <div style=\"padding: 32px;\">\n"
"        <p>Dear <t t-out=\"object.requested_by_id.name\"/>,</p>\n"
"        <p>Thank you for contacting us.</p>\n"
"        <p>\n"
"            Unfortunately we are unable to process your service request\n"
"            <strong><t t-out=\"object.ref\"/></strong> — <t t-out=\"object.name\"/> at this time.\n"
"        </p>\n"
"        <p>Please do not hesitate to contact our service team if you have any questions.</p>\n"
"        <p style=\"margin-top: 32px;\">Kind regards,<br/><strong>The Service Team</strong></p>\n"
"    </div>\n"
"    <div style=\"background-color: #f8f8f8; padding: 16px 32px; font-size: 12px; color: #888888;\">\n"
"        This is an automated message. Please do not reply directly to this email.\n"
"    </div>\n"
"</div>\n"
"        "
